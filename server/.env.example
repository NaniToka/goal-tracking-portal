PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/goal-tracking-portal?retryWrites=true&w=majority

# Access token (short-lived recommended in production: 15m)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Refresh token (use a different secret in production)
JWT_REFRESH_SECRET=your-refresh-secret-different-from-jwt-secret
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_DAYS=30

NODE_ENV=development
CLIENT_URL=http://localhost:5173
